        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AeroMed Service Deep Dive \u2014 per-service uptime, response time distribution, request rate, error rate",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "arrow-left",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Operations Overview",
      "tooltip": "Back to overview",
      "type": "link",
      "url": "/d/aeromed-operations-overview"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "repeat": null,
      "title": "API Gateway \u2014 Port 5000 (entry point for all external traffic)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "aeromed-prometheus"
      },
      "description": "Uptime percentage over selected time window",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "displayName": "Uptime %",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 99
              },
              {
                "color": "green",
                "value": 99.9
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 101,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "avg_over_time(up{job=\"aeromed-api-gateway\"}[$__range]) * 100",
          "instant": true,
          "legendFormat": "Uptime %",
          "refId": "A"
        }
      ],
      "title": "API Gateway \u2014 Uptime %",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "aeromed-prometheus"
      },
      "description": "Response time distribution heatmap \u2014 shows percentile spread over time",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 4,
        "y": 1
      },
      "id": 102,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "show": true
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "mode": "single",
          "showColorScale": false,
          "yHistogram": false
        },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "sum(rate(response_time_seconds_bucket{job=\"aeromed-api-gateway\"}[$__rate_interval])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{ le }}",
          "refId": "A"
        }
      ],
      "title": "API Gateway \u2014 Response Time Distribution",
      "type": "heatmap"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "aeromed-prometheus"
      },
      "description": "HTTP request throughput (requests per second)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 103,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "rate(http_requests_total{job=\"aeromed-api-gateway\"}[$__rate_interval])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "title": "API Gateway \u2014 Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "aeromed-prometheus"
      },
      "description": "HTTP 5xx error rate \u2014 red fill highlights when above 5% threshold",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 104,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "rate(http_requests_total{job=\"aeromed-api-gateway\",status=~\"5..\"}[$__rate_interval]) / rate(http_requests_total{job=\"aeromed-api-gateway\"}[$__rate_interval])",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "title": "API Gateway \u2014 Error Rate",
      "type": "timeseries"
    },
