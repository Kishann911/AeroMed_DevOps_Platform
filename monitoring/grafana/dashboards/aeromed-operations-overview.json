      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "count(up{job=~\"aeromed-.*\"} == 1)",
          "instant": true,
          "legendFormat": "Healthy Services",
          "refId": "A"
        }
      ],
      "title": "Platform Health",
      "type": "stat"
