        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "kube_pod_status_phase{namespace=\"aeromed-production\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "kube_pod_status_ready{namespace=\"aeromed-production\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "kube_pod_container_status_restarts_total{namespace=\"aeromed-production\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "C"
        }
      ],
      "title": "Pod Status",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "job": false
