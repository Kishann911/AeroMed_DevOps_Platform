      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "aeromed-prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(response_time_seconds_bucket{job=~\"aeromed-.*\"}[5m]))",
          "legendFormat": "{{ job }}",
          "refId": "A"
        }
      ],
      "title": "Service Response Times (p95)",
      "type": "timeseries"
